<style>
/* ═══ PRICING + FAQS COMBINED ═══ */
.pf-section{background:#070E23;padding:80px 0;color:#fff;overflow:hidden}
.pf-inner{max-width:1100px;margin:0 auto;padding:0 20px}

/* Pricing */
.pf-pricing-header{text-align:center;margin-bottom:48px}
.pf-pricing-header h2{font-size:clamp(2.2rem,5vw,3.2rem);text-transform:uppercase;letter-spacing:2px;margin-bottom:8px}
.pf-pricing-header p{font-size:1.05rem;color:#888}
.pf-pricing-header .pf-line{width:60px;height:3px;background:#E30517;margin:16px auto 0;border-radius:2px}
.pf-cards{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:80px}
.pf-card{border-radius:20px;padding:44px 36px;position:relative;overflow:hidden;transition:transform .4s cubic-bezier(.22,1,.36,1),box-shadow .4s}
.pf-card:hover{transform:translateY(-6px)}
.pf-card--primary{background:linear-gradient(135deg,#0f1a3a,#111827);border:2px solid #E30517;box-shadow:0 0 60px rgba(227,5,23,.1)}
.pf-card--primary:hover{box-shadow:0 20px 60px rgba(227,5,23,.2)}
.pf-card--secondary{background:linear-gradient(135deg,#111827,#0f1a3a);border:2px solid #1a2332}
.pf-card--secondary:hover{box-shadow:0 20px 60px rgba(0,0,0,.3)}
.pf-badge{display:inline-block;background:#E30517;color:#fff;padding:6px 20px;border-radius:100px;font-size:.75rem;text-transform:uppercase;font-weight:700;letter-spacing:1.5px;margin-bottom:20px}
.pf-badge--outline{background:transparent;border:1px solid #333;color:#888}
.pf-plan-name{font-size:.85rem;text-transform:uppercase;letter-spacing:3px;color:#666;margin-bottom:16px}
.pf-price{font-size:3.2rem;font-weight:900;color:#fff;line-height:1;margin-bottom:4px}
.pf-price span{font-size:1.2rem;font-weight:400;color:#666}
.pf-price-old{font-size:1rem;color:#555;text-decoration:line-through;margin-bottom:24px;display:block}
.pf-price-note{font-size:.85rem;color:#E30517;margin-bottom:24px;display:block;font-weight:600}
.pf-features{list-style:none;padding:0;margin:0 0 32px}
.pf-features li{padding:10px 0;border-bottom:1px solid rgba(255,255,255,.06);color:#bbb;font-size:.95rem;display:flex;align-items:center;gap:10px}
.pf-features li:last-child{border-bottom:none}
.pf-features li svg{width:18px;height:18px;flex-shrink:0}
.pf-features li svg.check{stroke:#E30517}
.pf-features li svg.x{stroke:#333}
.pf-features li.disabled{color:#444}
.pf-cta{display:block;text-align:center;padding:16px;border-radius:100px;font-size:1rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;text-decoration:none;transition:all .3s}
.pf-cta--red{background:#E30517;color:#fff}
.pf-cta--red:hover{background:#ff1a2e;box-shadow:0 8px 30px rgba(227,5,23,.4);transform:translateY(-2px)}
.pf-cta--outline{background:transparent;color:#fff;border:2px solid #333}
.pf-cta--outline:hover{border-color:#E30517;color:#E30517}
/* Glow effect on primary card */
.pf-card--primary::before{content:'';position:absolute;top:-50%;right:-50%;width:200%;height:200%;background:radial-gradient(circle,rgba(227,5,23,.06),transparent 50%);pointer-events:none}

/* Divider */
.pf-divider{display:flex;align-items:center;gap:16px;margin-bottom:56px}
.pf-divider::before,.pf-divider::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,transparent,#1a2332,transparent)}
.pf-divider span{font-size:.75rem;text-transform:uppercase;letter-spacing:3px;color:#444;white-space:nowrap}

/* FAQs */
.pf-faqs-header{text-align:center;margin-bottom:40px}
.pf-faqs-header h2{font-size:clamp(1.8rem,4vw,2.6rem);text-transform:uppercase;letter-spacing:2px;margin-bottom:8px}
.pf-faqs-header p{color:#888;font-size:1rem}
.pf-faq-list{max-width:800px;margin:0 auto}
.pf-faq{border:1px solid #1a2332;border-radius:12px;margin-bottom:10px;overflow:hidden;transition:border-color .3s}
.pf-faq.open{border-color:#E30517}
.pf-faq-q{display:flex;align-items:center;justify-content:space-between;padding:20px 24px;cursor:pointer;gap:16px;transition:background .3s}
.pf-faq-q:hover{background:rgba(255,255,255,.02)}
.pf-faq-q h3{font-size:1rem;font-weight:600;color:#fff;margin:0;flex:1}
.pf-faq-icon{width:28px;height:28px;border-radius:50%;background:#111827;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .3s}
.pf-faq.open .pf-faq-icon{background:#E30517;transform:rotate(45deg)}
.pf-faq-icon svg{width:14px;height:14px;stroke:#fff;stroke-width:2;fill:none;stroke-linecap:round}
.pf-faq-a{max-height:0;overflow:hidden;transition:max-height .4s ease}
.pf-faq.open .pf-faq-a{max-height:300px}
.pf-faq-a-inner{padding:0 24px 20px;color:#999;font-size:.95rem;line-height:1.7}
/* Number indicator */
.pf-faq-num{font-size:.75rem;font-weight:700;color:#E30517;margin-right:12px;font-family:monospace;min-width:20px}

@media(max-width:768px){
.pf-cards{grid-template-columns:1fr}
.pf-card{padding:32px 24px}
.pf-price{font-size:2.6rem}
}
</style>

<section class="pf-section">
  <div class="pf-inner">
    <!-- PRICING -->
    <div class="pf-pricing-header">
      <h2>{{ section.settings.pricing_heading }}</h2>
      <p>{{ section.settings.pricing_subheading }}</p>
      <div class="pf-line"></div>
    </div>
    <div class="pf-cards">
      <!-- Plan 1 -->
      <div class="pf-card pf-card--primary">
        <span class="pf-badge">{{ section.settings.plan1_badge }}</span>
        <div class="pf-plan-name">{{ section.settings.plan1_name }}</div>
        <div class="pf-price">${{ section.settings.plan1_price }}<span>/mes</span></div>
        {% if section.settings.plan1_old_price != blank %}
        <span class="pf-price-old">${{ section.settings.plan1_old_price }} precio normal</span>
        {% endif %}
        {% if section.settings.plan1_note != blank %}
        <span class="pf-price-note">{{ section.settings.plan1_note }}</span>
        {% endif %}
        <ul class="pf-features">
          {% assign features1 = section.settings.plan1_features | split: '|' %}
          {% for feature in features1 %}
          <li><svg class="check" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>{{ feature | strip }}</li>
          {% endfor %}
        </ul>
        <a href="{{ section.settings.plan1_link }}" class="pf-cta pf-cta--red">{{ section.settings.plan1_cta }}</a>
      </div>
      <!-- Plan 2 -->
      <div class="pf-card pf-card--secondary">
        <span class="pf-badge pf-badge--outline">{{ section.settings.plan2_badge }}</span>
        <div class="pf-plan-name">{{ section.settings.plan2_name }}</div>
        <div class="pf-price">${{ section.settings.plan2_price }}<span>/mes</span></div>
        {% if section.settings.plan2_old_price != blank %}
        <span class="pf-price-old">${{ section.settings.plan2_old_price }}</span>
        {% endif %}
        {% if section.settings.plan2_note != blank %}
        <span class="pf-price-note" style="color:#888">{{ section.settings.plan2_note }}</span>
        {% endif %}
        <ul class="pf-features">
          {% assign features2 = section.settings.plan2_features | split: '|' %}
          {% for feature in features2 %}
          {% assign is_disabled = feature | strip | slice: 0, 1 %}
          {% if is_disabled == '~' %}
          <li class="disabled"><svg class="x" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>{{ feature | strip | remove_first: '~' }}</li>
          {% else %}
          <li><svg class="check" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>{{ feature | strip }}</li>
          {% endif %}
          {% endfor %}
        </ul>
        <a href="{{ section.settings.plan2_link }}" class="pf-cta pf-cta--outline">{{ section.settings.plan2_cta }}</a>
      </div>
    </div>

    <!-- DIVIDER -->
    <div class="pf-divider"><span>Preguntas Frecuentes</span></div>

    <!-- FAQS -->
    <div class="pf-faqs-header">
      <h2>{{ section.settings.faqs_heading }}</h2>
      <p>{{ section.settings.faqs_subheading }}</p>
    </div>
    <div class="pf-faq-list">
      {% for block in section.blocks %}
      <div class="pf-faq" {{ block.shopify_attributes }}>
        <div class="pf-faq-q" onclick="this.parentElement.classList.toggle('open')">
          <h3><span class="pf-faq-num">0{{ forloop.index }}</span>{{ block.settings.question }}</h3>
          <div class="pf-faq-icon"><svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></div>
        </div>
        <div class="pf-faq-a">
          <div class="pf-faq-a-inner">{{ block.settings.answer }}</div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Precios + FAQs",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Precios" },
    { "type": "text", "id": "pricing_heading", "label": "Título precios", "default": "ELIGE TU PLAN" },
    { "type": "text", "id": "pricing_subheading", "label": "Subtítulo", "default": "Entrena con peleadores profesionales" },
    { "type": "header", "content": "Plan 1 (Destacado)" },
    { "type": "text", "id": "plan1_badge", "label": "Badge", "default": "Más Popular" },
    { "type": "text", "id": "plan1_name", "label": "Nombre del plan", "default": "Plan Completo" },
    { "type": "text", "id": "plan1_price", "label": "Precio", "default": "150.000" },
    { "type": "text", "id": "plan1_old_price", "label": "Precio anterior (tachado)" },
    { "type": "text", "id": "plan1_note", "label": "Nota del precio" },
    { "type": "textarea", "id": "plan1_features", "label": "Características (separadas por |)", "default": "Plan de entrenamiento personalizado|Guía de alimentación completa|8 clases presenciales al mes|Grupo de Telegram con coaches|Acceso completo a la app|Seguimiento personalizado" },
    { "type": "text", "id": "plan1_cta", "label": "Texto del botón", "default": "QUIERO ESTE PLAN" },
    { "type": "url", "id": "plan1_link", "label": "Link del botón" },
    { "type": "header", "content": "Plan 2" },
    { "type": "text", "id": "plan2_badge", "label": "Badge", "default": "Básico" },
    { "type": "text", "id": "plan2_name", "label": "Nombre del plan", "default": "Plan Base" },
    { "type": "text", "id": "plan2_price", "label": "Precio", "default": "120.000" },
    { "type": "text", "id": "plan2_old_price", "label": "Precio anterior" },
    { "type": "text", "id": "plan2_note", "label": "Nota del precio" },
    { "type": "textarea", "id": "plan2_features", "label": "Características (| para separar, ~ para deshabilitada)", "default": "Plan de entrenamiento personalizado|Guía de alimentación completa|4 clases presenciales al mes|Grupo de Telegram con coaches|Acceso completo a la app|~Seguimiento personalizado" },
    { "type": "text", "id": "plan2_cta", "label": "Texto del botón", "default": "EMPEZAR AHORA" },
    { "type": "url", "id": "plan2_link", "label": "Link del botón" },
    { "type": "header", "content": "FAQs" },
    { "type": "text", "id": "faqs_heading", "label": "Título FAQs", "default": "¿TIENES DUDAS?" },
    { "type": "text", "id": "faqs_subheading", "label": "Subtítulo", "default": "Resolvemos las preguntas más comunes" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Pregunta",
      "settings": [
        { "type": "text", "id": "question", "label": "Pregunta", "default": "¿Pregunta frecuente?" },
        { "type": "richtext", "id": "answer", "label": "Respuesta" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Precios + FAQs",
      "blocks": [
        { "type": "faq", "settings": { "question": "¿Pregunta de ejemplo?", "answer": "<p>Respuesta de ejemplo.</p>" } }
      ]
    }
  ]
}
{% endschema %}
